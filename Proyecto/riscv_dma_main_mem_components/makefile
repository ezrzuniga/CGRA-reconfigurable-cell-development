#=========================================================
# Project name
#=========================================================

TARGET = cgra_platform


#=========================================================
# Compiler
#=========================================================

CXX = g++
CXXFLAGS = -Wall -Wextra -std=c++17


#=========================================================
# SystemC installation
#=========================================================

SYSTEMC_HOME = /usr/local/systemc

INCLUDES = -I$(SYSTEMC_HOME)/include

LIBS = -L$(SYSTEMC_HOME)/lib-linux64 \
       -lsystemc \
       -lm


#=========================================================
# Source files
#=========================================================

SOURCES = \
	main.cpp \
	top.cpp \
	main_memory.cpp \
	csr_dma.cpp \
	riscv_core.cpp \
	dummy_cgra.cpp


#=========================================================
# Object files
#=========================================================

OBJECTS = $(SOURCES:.cpp=.o)


#=========================================================
# Build target
#=========================================================

all: $(TARGET)


#=========================================================
# Link everything
#=========================================================

$(TARGET): $(OBJECTS)
	$(CXX) $(OBJECTS) -o $(TARGET) $(LIBS)


#=========================================================
# Compile .cpp files
#=========================================================

%.o: %.cpp
	$(CXX) $(CXXFLAGS) $(INCLUDES) -c $< -o $@


#=========================================================
# Run the simulation
#=========================================================

run: $(TARGET)
	./$(TARGET)


#=========================================================
# Clean generated files
#=========================================================

clean:
	rm -f *.o $(TARGET)


#=========================================================
# Rebuild everything
#=========================================================

rebuild: clean all